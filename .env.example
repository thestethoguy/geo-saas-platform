# Copy this file to .env and fill in your own values.
# Never commit .env — it is listed in .gitignore.
#
# ── Cloud providers (Render / Railway / Heroku) ───────────────────────────────
# Set these single-URL vars in the Render dashboard and the API will use them
# automatically — no other Postgres/Redis vars are needed in production.
#
#   DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
#   REDIS_URL=redis://:password@host:6379
#
# ── Local development (docker-compose) ────────────────────────────────────────
# Used only when DATABASE_URL / REDIS_URL are NOT set.

# ─── PostgreSQL ───────────────────────────────
POSTGRES_USER=geouser
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=geosaas
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# ─── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ─── Typesense ────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http        # set to "https" in production (port 443)
TYPESENSE_API_KEY=your_typesense_api_key_here

# ─── App ──────────────────────────────────────
APP_PORT=8080
APP_ENV=development
LOG_LEVEL=debug
